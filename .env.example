# ============================================================
# ARCHIVO DE REFERENCIA DE VARIABLES DE ENTORNO
# Copiar a .env y rellenar los valores reales
# NUNCA subir .env al repositorio (verificar .gitignore)
# ============================================================

HOST=0.0.0.0
PORT=5000

# ─────────────────────────────────────────────────────
# SMTP - Envio de correos
# ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contrasenna_de_aplicacion

# ─────────────────────────────────────────────────────
# PASARELA DE COBRO QR
# Req 2:  Autenticacion mediante x-api-key
# Req 11: Ambientes TEST y PRODUCCION independientes
# ─────────────────────────────────────────────────────

# Ambiente activo: TEST | PRODUCCION
# Cambiar a PRODUCCION SOLO despues de completar pruebas exitosas en TEST
QR_AMBIENTE=TEST

# ── Ambiente TEST / Sandbox ──────────────────────────
# URL y token proporcionados por la pasarela para pruebas
QR_API_URL_TEST=https://api-test.pasarela-qr.com
QR_API_KEY_TEST=TOKEN_TEST_PROPORCIONADO_POR_PASARELA

# ── Ambiente PRODUCCION ──────────────────────────────
# URL y token proporcionados por la pasarela para produccion
# Completar SOLO despues de aprobar pruebas en TEST
QR_API_URL_PROD=https://api.pasarela-qr.com
QR_API_KEY_PROD=TOKEN_PRODUCCION_PROPORCIONADO_POR_PASARELA

# Tiempo de vigencia del QR en horas (Req 3: max 8760h)
QR_EXPIRACION_HORAS=24

# Secret compartido con la pasarela para validar firma del webhook (Req 10)
# Solicitar este valor al proveedor de la pasarela
# Dejar vacio si la pasarela no envía firma en el webhook
QR_WEBHOOK_SECRET=SECRET_COMPARTIDO_CON_PASARELA

# ─────────────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_bd
DB_NAME=entradas_db
DB_POOL_SIZE=50

# ─────────────────────────────────────────────────────
# CRON - Expiracion de registros pendientes
# ─────────────────────────────────────────────────────
# Minutos maximos para expirar compras en PAGO_PENDIENTE
EXPIRAR_PENDIENTES_MINUTOS=15